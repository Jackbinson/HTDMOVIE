# Step 1: Build stage
FROM node:20-alpine as build
WORKDIR /app

# 1. Copy TOÀN BỘ code từ máy bạn vào Docker
COPY . .

# 2. ✅ TUYỆT CHIÊU: Xóa sạch thư mục node_modules và file lock của Windows (nếu lỡ bị copy vào)
RUN rm -rf node_modules package-lock.json

# 3. Ép Linux tự tải các thư viện dành riêng cho nó từ đầu
RUN npm install --legacy-peer-deps
RUN npm install vite@latest @vitejs/plugin-react@latest --save-dev --legacy-peer-deps

# 4. Build dự án
RUN npm run build

# Step 2: Production stage
FROM nginx:stable-alpine
COPY --from=build /app/dist /usr/share/nginx/html
EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]